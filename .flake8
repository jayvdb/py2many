[flake8]
per-file-ignores =
    # imported but unused
    __init__.py: F401
extend_ignore = E711, E712, E713, E731, E741, E721, E722
max-line-length = 140
exclude =
    # No need to traverse our git directory
    .git,
    # There's no value in checking cache directories
    __pycache__,
    build,
    # local-only dirs created by tox/venv/setuptools, not present in CI
    .tox,
    .venv,
    py2many.egg-info,
    # generated files
    tests/expected,
    tests/cases,
    tests/dir_cases,
    tests/ext_cases,
